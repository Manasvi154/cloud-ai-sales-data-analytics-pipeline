{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowCloudWatchLogs",
      "Effect": "Allow",
      "Action": [
        "logs:CreateLogGroup",
        "logs:CreateLogStream",
        "logs:PutLogEvents"
      ],
      "Resource": "*"
    },
    {
      "Sid": "AllowDynamoDBJobsEvents",
      "Effect": "Allow",
      "Action": [
        "dynamodb:GetItem",
        "dynamodb:PutItem",
        "dynamodb:UpdateItem",
        "dynamodb:Query"
      ],
      "Resource": [
        "arn:aws:dynamodb:REPLACE_REGION:REPLACE_ACCOUNT_ID:table/analytics_jobs",
        "arn:aws:dynamodb:REPLACE_REGION:REPLACE_ACCOUNT_ID:table/analytics_events"
      ]
    },
    {
      "Sid": "AllowS3ReadWriteArtifacts",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject",
        "s3:ListBucket"
      ],
      "Resource": [
        "arn:aws:s3:::REPLACE_DATA_BUCKET",
        "arn:aws:s3:::REPLACE_DATA_BUCKET/*"
      ]
    },
    {
      "Sid": "AllowSageMakerDescribe",
      "Effect": "Allow",
      "Action": [
        "sagemaker:DescribeTrainingJob"
      ],
      "Resource": "*"
    },
    {
      "Sid": "AllowQuickSightActions",
      "Effect": "Allow",
      "Action": [
        "quicksight:CreateIngestion",
        "quicksight:GenerateEmbedUrlForRegisteredUser"
      ],
      "Resource": "*"
    },
    {
      "Sid": "AllowBedrockModelInvocation",
      "Effect": "Allow",
      "Action": [
        "bedrock:InvokeModel",
        "bedrock:Converse"
      ],
      "Resource": "*"
    }
  ]
}
