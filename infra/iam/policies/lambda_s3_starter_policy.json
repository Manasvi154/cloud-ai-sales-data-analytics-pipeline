{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowCloudWatchLogs",
      "Effect": "Allow",
      "Action": [
        "logs:CreateLogGroup",
        "logs:CreateLogStream",
        "logs:PutLogEvents"
      ],
      "Resource": "*"
    },
    {
      "Sid": "AllowReadUploadObjectMetadata",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:GetObjectAttributes",
        "s3:HeadObject"
      ],
      "Resource": "arn:aws:s3:::REPLACE_DATA_BUCKET/*"
    },
    {
      "Sid": "AllowStepFunctionsStart",
      "Effect": "Allow",
      "Action": [
        "states:StartExecution"
      ],
      "Resource": "REPLACE_STEP_FUNCTION_ARN"
    },
    {
      "Sid": "AllowJobsEventsTables",
      "Effect": "Allow",
      "Action": [
        "dynamodb:GetItem",
        "dynamodb:PutItem",
        "dynamodb:UpdateItem"
      ],
      "Resource": [
        "arn:aws:dynamodb:REPLACE_REGION:REPLACE_ACCOUNT_ID:table/analytics_jobs",
        "arn:aws:dynamodb:REPLACE_REGION:REPLACE_ACCOUNT_ID:table/analytics_events"
      ]
    }
  ]
}
